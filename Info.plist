<?xml version="1.0" encoding="UTF-8"?>
<!--
    Explicit Info.plist for the Issues target (#0110).

    Migrated off `GENERATE_INFOPLIST_FILE` so we can declare the
    `NSAppTransportSecurity` dictionary needed for the v1 remote-access
    plain-HTTP path. ATS is intentionally disabled app-wide because the
    remote-access design uses plain HTTP on local networks (LAN /
    Tailscale); the bearer-token model is the auth boundary, not TLS.

    The TLS migration tracked in #0111 will re-enable ATS (via cert
    pinning in #0114), so this exception is the v1 → v2 bridge.

    The original v2 plan was to add `NSBonjourServices` here for the
    Bonjour discovery cluster, but that's been wontfix'd by #0124 — the
    Mac mini is the canonical host and viewers connect by direct
    address. The Bonjour-related keys never land.

    Keys whose values come from `INFOPLIST_KEY_*` / project build
    settings use `$(BUILD_SETTING)` substitutions so we don't drift
    from the build config. Xcode's `builtin-infoPlistUtility` still
    merges remaining `INFOPLIST_KEY_*` settings into this file at
    build time.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <!--
        #0114 removed the NSAppTransportSecurity dict that #0110 added.
        Cert pinning via PinnedHostSessionDelegate makes the broad
        exception unnecessary — https:// + ECDHE on a self-signed
        P-256 cert satisfies ATS's protocol + forward-secrecy
        requirements; the delegate's URLCredential(trust:) bypasses
        ATS's chain-validation check cleanly.

        Info.plist itself stays — it carries the URL scheme below
        (#0119) and is where any future explicit-plist additions land.
    -->
    <key>NSHumanReadableCopyright</key>
    <string></string>
    <!--
        Custom URL scheme `issues://` (#0119). Used by the standalone
        `issues` CLI to ask the running app (or relaunch it) to open or
        activate a folder by path. SwiftUI's `onOpenURL` on `RootView`
        receives the event; `TabsModel.openOrActivate(folderPath:)`
        handles the three branches (already-open, remembered, new).
    -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>issues</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
        </dict>
    </array>
</dict>
</plist>
