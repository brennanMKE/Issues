    "Rotating the certificate invalidates every access token issued against the current certificate. All connected viewers will be disconnected and must paste a new token before they can reconnect." : {
      "comment" : "A message displayed in a confirmation dialog when rotating a server certificate.",
      "isCommentAutoGenerated" : true
    },
    "Rotation invalidates every existing access token. All viewers will need a fresh token." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
