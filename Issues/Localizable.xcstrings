            "state" : "translated",
            "value" : "La rotación invalida todos los tokens de acceso existentes. Todos los visores necesitarán un token nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renouveler le certificat invalide tous les jetons d’accès existants. Toutes les visionneuses auront besoin d’un nouveau jeton."
