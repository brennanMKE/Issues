
SWIFT_VERSION = 6.0
ENABLE_APP_SANDBOX = NO
SWIFT_APPROACHABLE_CONCURRENCY = YES
SWIFT_DEFAULT_ACTOR_ISOLATION = MainActor

// Deployment target tracks "current macOS minus 1". Apple jumped 15 → 26
// across all OS platforms in 2026 to align with the year, so the project
// supports macOS 15 (Sequoia) as well as macOS 26 and later.
MACOSX_DEPLOYMENT_TARGET = 15.0

SUPPORTED_PLATFORMS = macosx

SUPPORTS_MACCATALYST = NO

CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM = XV8BAAVZ6V

// Macs only — SDKROOT itself selects the SDK, so don't condition it on the SDK.
SDKROOT = macosx

// Avoid using double slash which becomes a comment
HTTPS=https:/

// Sparkle
SU_FEED_URL = $HTTPS/issues.sstools.co/appcast.xml
SU_PUBLIC_ED_KEY = i6t0gJDorD/84Ln1AyQBQ27Ibd3pbnVMvEPMUvbBi7M=
